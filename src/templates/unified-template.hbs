{{!-- <!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 0; margin: 0; color: #333; line-height: 1.6; }
        .container { padding: 40px; }
        .header { display: flex; justify-content: space-between; border-bottom: 2px solid #1a5f7a; padding-bottom: 20px; margin-bottom: 30px; }
        .logo-box h1 { color: #1a5f7a; margin: 0; font-size: 28px; }
        .info-box { text-align: right; }
        .section-title { background: #f4f7f8; padding: 10px; color: #1a5f7a; font-weight: bold; text-transform: uppercase; margin-top: 30px; border-left: 5px solid #1a5f7a; }
        .client-grid { display: grid; grid-template-columns: 1fr 1fr; margin-top: 20px; gap: 20px; }
        .card { border: 1px solid #e1e1e1; padding: 15px; border-radius: 4px; margin-top: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background: #1a5f7a; color: white; padding: 12px; text-align: left; }
        td { padding: 12px; border-bottom: 1px solid #eee; }
        .totals-table { width: 300px; margin-left: auto; margin-top: 20px; }
        .total-row { font-weight: bold; color: #1a5f7a; font-size: 18px; }
        .footer { margin-top: 50px; font-size: 12px; color: #777; border-top: 1px solid #eee; padding-top: 10px; }
        .badge { display: inline-block; padding: 4px 8px; border-radius: 12px; background: #e3f2fd; color: #1565c0; font-size: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo-box">
                <h1>KLAR TRAVELS</h1>
                <p>Itinerary & Quote</p>
            </div>
            <div class="info-box">
                <p><strong>Quote No:</strong> {{quote.quote_number}}</p>
                <p><strong>Date:</strong> {{formatDate quote.created_at}}</p>
                <p><strong>Valid Until:</strong> {{formatDate quote.valid_until}}</p>
            </div>
        </div>

        <div class="client-grid">
            <div>
                <p><strong>Prepared For:</strong></p>
                <p>{{itinerary.lead_details.name}}</p>
                <p>{{itinerary.lead_details.email}}</p>
                <p>{{itinerary.lead_details.phone}}</p>
            </div>
            <div style="text-align: right;">
                <p><strong>Status:</strong> <span class="badge">{{quote.status}}</span></p>
                <p><strong>Destination:</strong> {{itinerary.service_preferences.0.preferences.destination}}</p>
            </div>
        </div>

        <div class="section-title">Travel Itinerary</div>
        {{#each itinerary.service_preferences}}
        <div class="card">
            <h3>{{this.title}}</h3>
            <p><strong>Description:</strong> {{this.description}}</p>
            <p><strong>Duration:</strong> {{this.preferences.duration}} Days</p>
            <p><strong>Dates:</strong> {{this.preferences.tour_start_date}} to {{this.preferences.tour_end_date}}</p>
            <p><strong>Inclusions:</strong> {{this.preferences.inclusions}}</p>
            {{#if this.preferences.special_requirements}}
            <p><strong>Special Requirements:</strong> {{this.preferences.special_requirements}}</p>
            {{/if}}
        </div>
        {{/each}}

        <div class="section-title">Commercial Quote</div>
        <table>
            <thead>
                <tr>
                    <th>Service Description</th>
                    <th style="text-align: center;">Qty</th>
                    <th style="text-align: right;">Unit Price</th>
                    <th style="text-align: right;">Total</th>
                </tr>
            </thead>
            <tbody>
                {{#each quote.line_items}}
                <tr>
                    <td>
                        <strong>{{this.description}}</strong><br>
                        <small>{{this.details.service_code}}</small>
                    </td>
                    <td style="text-align: center;">{{this.quantity}}</td>
                    <td style="text-align: right;">{{formatCurrency this.unit_price ../quote.currency}}</td>
                    <td style="text-align: right;">{{formatCurrency this.total ../quote.currency}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <table class="totals-table">
            <tr>
                <td>Subtotal</td>
                <td style="text-align: right;">{{formatCurrency quote.totals.subtotal quote.currency}}</td>
            </tr>
            <tr>
                <td>Tax ({{quote.totals.tax_rate}}%)</td>
                <td style="text-align: right;">{{formatCurrency quote.totals.tax_amount quote.currency}}</td>
            </tr>
            <tr class="total-row">
                <td>Grand Total</td>
                <td style="text-align: right;">{{formatCurrency quote.totals.final_amount quote.currency}}</td>
            </tr>
        </table>

        <div class="section-title">Terms & Conditions</div>
        <div class="card" style="font-size: 13px;">
            {{quote.terms_conditions}}
        </div>

        <div class="footer">
            <p>This is a computer-generated document. No signature required.</p>
            <p>&copy; 2026 Klar Travels. All Rights Reserved.</p>
        </div>
    </div>
</body>
</html> --}}